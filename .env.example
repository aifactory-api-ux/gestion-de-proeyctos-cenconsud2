# Auth
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=60

# Frontend
FRONTEND_URL=https://app.cenconsud2.com
NODE_ENV=production
VITE_API_URL=http://localhost:8004

# Messaging
SQS_QUEUE_URL=
SNS_TOPIC_ARN=

# Logging
LOG_LEVEL=INFO