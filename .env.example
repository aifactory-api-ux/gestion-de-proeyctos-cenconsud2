# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cenconsud2
POSTGRES_USER=cenconsud2_user
POSTGRES_PASSWORD=supersecret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS
AWS_REGION=us-east-1
SAGEMAKER_ENDPOINT=cenconsud2-forecast-prod
